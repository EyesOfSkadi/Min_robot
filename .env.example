# Sao chép thành .env (khi chạy local với `vercel dev`) hoặc đặt làm
# Environment Variables trong dashboard Vercel (Project → Settings → Environment Variables).

# Khoá API Claude (lấy ở https://console.anthropic.com/ → API Keys):
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Tuỳ chọn — Haiku 4.5 rẻ & nhanh (hợp trò chuyện). Đổi sang claude-sonnet-4-6 nếu muốn thông minh hơn.
LLM_MODEL=claude-haiku-4-5-20251001
WEATHER_CITY=Ho Chi Minh
HISTORY_PROMPT_N=24
